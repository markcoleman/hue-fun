{
  "name": "newhue-client",
  "version": "0.1.0",
  "description": "TypeScript client and helpers for the Philips Hue CLIP v2 API.",
  "keywords": [
    "philips-hue",
    "hue",
    "openapi",
    "typescript"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "bin": {
    "hue": "./dist/hue.mjs",
    "hue-mcp": "./dist/hue-mcp.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "src/generated"
  ],
  "scripts": {
    "generate": "openapi-ts -f openapi-ts.config.ts",
    "generate:check": "tsx scripts/check-generated.ts",
    "build": "tsdown",
    "build:exe": "npm run build && tsx scripts/build-exe.ts",
    "validate": "tsx scripts/validate.ts",
    "cli": "tsx src/cli/bin.ts",
    "mcp": "tsx src/mcp/bin.ts",
    "mcp:http": "tsx src/mcp/bin.ts --transport http",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "typedoc",
    "harness": "tsx scripts/harness.ts",
    "pages:build": "tsx scripts/build-site.ts"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.94.1",
    "@types/node": "^25.5.0",
    "@types/prompts": "2.4.9",
    "postject": "1.0.0-alpha.6",
    "tsdown": "^0.21.4",
    "tsx": "^4.20.5",
    "typedoc": "^0.28.13",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "yaml": "^2.8.2"
  },
  "inlinedDependencies": {
    "commander": "14.0.3",
    "kleur": "3.0.3",
    "picocolors": "1.1.1",
    "prompts": "2.4.2",
    "sisteransi": "1.0.5",
    "yaml": "2.8.2"
  }
}
